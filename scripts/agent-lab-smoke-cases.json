{
  "cases": [
    {
      "id": "vulhub-struts2-s2-045",
      "name": "Vulhub Apache Struts2 S2-045 local smoke",
      "labRoot": "labs/targets/vulhub/struts2/s2-045",
      "labPathHints": [
        "s2-045",
        "struts2/s2-045",
        "struts2\\s2-045"
      ],
      "target": {
        "defaultUrl": "http://127.0.0.1:8080/"
      },
      "expect": {
        "auth": {
          "login": "not_observed",
          "authState": "unknown",
          "authEndpointsEmpty": true
        },
        "normalizedApiIncludes": [
          {
            "method": "POST",
            "pathTemplate": "/doUpload.action",
            "absentRiskSignals": [
              "auth-surface"
            ]
          }
        ],
        "queueBeforeFirstFallbackFor": "authz-plan",
        "queueAfterAbsentTitles": [
          "Collect authenticated roles before business-impact testing"
        ],
        "control": {
          "stageIn": [
            "ready_for_business_planning",
            "needs_auth_contexts",
            "ready_for_validation_review"
          ],
          "minNormalizedApiEndpoints": 1,
          "decisionGuardIncludes": [
            "Prefer normalized API routes"
          ]
        },
        "operatingPicture": {
          "minEndpointMap": 1,
          "decisionFrameIncludes": [
            "not from a fixed phase list"
          ],
          "blockedIncludes": [
            "Cross-role"
          ],
          "allowedActionIncludes": [
            "normalized routes"
          ]
        }
      },
      "safeProof": {
        "kind": "responseHeader",
        "activeApprovalRequired": true,
        "method": "POST",
        "path": "/doUpload.action",
        "headers": {
          "Content-Type": "%{(#_='multipart/form-data').(#dm=@ognl.OgnlContext@DEFAULT_MEMBER_ACCESS).(#_memberAccess?(#_memberAccess=#dm):((#container=#context['com.opensymphony.xwork2.ActionContext.container']).(#ognlUtil=#container.getInstance(@com.opensymphony.xwork2.ognl.OgnlUtil@class)).(#ognlUtil.getExcludedPackageNames().clear()).(#ognlUtil.getExcludedClasses().clear()).(#context.setMemberAccess(#dm)))).(@org.apache.struts2.ServletActionContext@getResponse().addHeader('X-AegisProbe-Proof','vulhub-54289'))}"
        },
        "expectHeader": {
          "name": "X-AegisProbe-Proof",
          "value": "vulhub-54289"
        },
        "finding": {
          "title": "Lab proof validated: Apache Struts2 S2-045 OGNL expression execution",
          "severity": "critical",
          "description": "A scoped local-lab proof caused the application to return a controlled response header through OGNL expression evaluation. The proof did not read files, write files, open a shell, or execute an OS command.",
          "remediation": "Upgrade Apache Struts2 to a fixed release and remove vulnerable file upload interceptor handling."
        }
      }
    },
    {
      "id": "vulhub-flask-ssti",
      "name": "Vulhub Flask Jinja2 SSTI local smoke",
      "labRoot": "labs/targets/vulhub/flask/ssti",
      "labPathHints": [
        "ssti",
        "flask/ssti",
        "flask\\ssti"
      ],
      "target": {
        "defaultUrl": "http://127.0.0.1:8000/",
        "preferredPorts": [
          8000
        ],
        "seedPaths": [
          "/?name=aegisprobe"
        ]
      },
      "expect": {
        "auth": {
          "login": "not_observed"
        },
        "normalizedApiIncludes": [
          {
            "method": "GET",
            "pathTemplate": "/"
          }
        ],
        "control": {
          "stageIn": [
            "ready_for_business_planning",
            "passive_mapping_only"
          ],
          "minNormalizedApiEndpoints": 1,
          "minRouteFrontier": 1,
          "decisionGuardIncludes": [
            "Do not run endpoint/payload testing without endpoint and parameter/body evidence"
          ]
        },
        "operatingPicture": {
          "minEndpointMap": 1,
          "decisionFrameIncludes": [
            "not from a fixed phase list"
          ],
          "blockedIncludes": [
            "Cross-role"
          ],
          "allowedActionIncludes": [
            "normalized routes"
          ]
        }
      },
      "safeProof": {
        "kind": "responseStatusComparison",
        "activeApprovalRequired": true,
        "control": {
          "method": "GET",
          "path": "/?name=aegisprobe"
        },
        "candidate": {
          "method": "GET",
          "path": "/?name=%7B%7B233*233%7D%7D"
        },
        "expect": {
          "controlStatus": 200,
          "candidateStatus": 200,
          "candidateBodyContains": "54289"
        },
        "finding": {
          "title": "Lab proof validated: Flask Jinja2 server-side template expression evaluation",
          "severity": "high",
          "description": "A scoped local-lab proof showed that a benign arithmetic template expression was evaluated by the Flask/Jinja2 response. The proof did not read files, write files, import modules, execute commands, or mutate server state.",
          "remediation": "Avoid rendering user-controlled strings as templates; pass user input only as escaped template variables and enable appropriate template sandboxing where applicable."
        }
      }
    },
    {
      "id": "vulhub-spring-cve-2022-22978",
      "name": "Vulhub Spring Security CVE-2022-22978 authorization bypass smoke",
      "labRoot": "labs/targets/vulhub/spring/CVE-2022-22978",
      "labPathHints": [
        "CVE-2022-22978",
        "spring/CVE-2022-22978",
        "spring\\CVE-2022-22978"
      ],
      "target": {
        "defaultUrl": "http://127.0.0.1:8080/",
        "seedPaths": [
          "/admin"
        ]
      },
      "expect": {
        "auth": {
          "authState": "anonymous"
        },
        "pagesVisitedIncludePaths": [
          "/admin"
        ],
        "queueAfterAbsentTitles": [
          "Collect authenticated roles before business-impact testing"
        ],
        "control": {
          "stageIn": [
            "needs_auth_contexts",
            "ready_for_business_planning",
            "ready_for_validation_review"
          ],
          "minNormalizedApiEndpoints": 1,
          "decisionGuardIncludes": [
            "Prefer normalized API routes"
          ]
        },
        "operatingPicture": {
          "minEndpointMap": 1,
          "decisionFrameIncludes": [
            "not from a fixed phase list"
          ],
          "blockedIncludes": [
            "Cross-role"
          ],
          "allowedActionIncludes": [
            "normalized routes"
          ]
        }
      },
      "safeProof": {
        "kind": "responseStatusComparison",
        "activeApprovalRequired": true,
        "control": {
          "method": "GET",
          "path": "/admin"
        },
        "candidate": {
          "method": "GET",
          "path": "/admin/%0atest"
        },
        "expect": {
          "controlStatus": 404,
          "candidateStatus": 200,
          "candidateBodyContains": "Congratulations, you are an admin!"
        },
        "finding": {
          "title": "Lab proof validated: Spring Security authorization bypass",
          "severity": "high",
          "description": "A scoped local-lab proof showed that an unauthenticated request to the protected admin path is denied, while a newline path variant reaches the protected resource. The proof only compared HTTP responses and did not modify server state.",
          "remediation": "Upgrade Spring Security to a fixed release and avoid RegexRequestMatcher patterns that can be bypassed by encoded newline path variants."
        }
      }
    },
