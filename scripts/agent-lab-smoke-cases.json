    {
      "id": "local-multirole",
      "name": "Local multi-role web app — authorization smoke (BOLA/BFLA/tenant isolation)",
      "labRoot": "labs/targets/local-multirole-app",
      "labPathHints": [
        "local-multirole-app"
      ],
      "target": {
        "defaultUrl": "http://127.0.0.1:3100/"
      },
      "start": {
        "command": "node",
        "args": [
          "server.js"
        ],
        "cwd": "labs/targets/local-multirole-app",
        "readyUrl": "http://127.0.0.1:3100/",
        "timeoutMs": 15000
      },
      "expect": {
        "auth": {
          "login": "present",
          "authState": "anonymous"
        },
        "pagesVisitedIncludePaths": [
          "/",
          "/login"
        ],
        "normalizedApiIncludes": [
          {
            "method": "GET",
            "pathTemplate": "/api/me"
          },
          {
            "method": "GET",
            "pathTemplate": "/api/orders/{id}"
          },
          {
            "method": "GET",
            "pathTemplate": "/api/admin/users/{id}"
          }
        ],
        "queueAfterAbsentTitles": [
          "Register one additional approved role, user, or tenant"
        ],
        "control": {
          "stageIn": [
            "needs_auth_contexts",
            "ready_for_authz_compare",
            "ready_for_business_planning",
            "ready_for_validation_review"
          ],
          "minNormalizedApiEndpoints": 3,
          "minRouteFrontier": 2,
          "decisionGuardIncludes": [
            "Prefer normalized API routes",
            "Do not run endpoint/payload testing without endpoint and parameter/body evidence"
          ]
        },
        "operatingPicture": {
          "minEndpointMap": 3,
          "decisionFrameIncludes": [
            "not from a fixed phase list"
          ],
          "beforeBlockedIncludes": [
            "Cross-role"
          ],
          "allowedActionIncludes": [
            "normalized routes"
          ],
          "authNextEvidenceIncludes": [
            "Run read-only"
          ],
          "beforeAuthNextEvidenceIncludes": [
            "Register"
          ]
        },
        "redaction": {
          "noHighEntropyParamHints": true
        },
        "expertSnapshotContains": [
          "Access exposure map",
          "Payload affordances",
          "/api/admin/users/{id}"
        ],
        "performance": {
          "maxReconMs": 60000,
          "maxTotalMs": 90000
        }
      },
      "safeProof": {
        "kind": "multiRoleAuthz",
        "description": "Register two auth contexts, login via JWT, and verify read-only cross-role comparison produces candidate finding. With expected policy, finding confidence upgrades to validated.",
        "authContexts": [
          {
            "name": "alice",
            "role": "customer",
            "tenant": "tenant-a",
            "username": "alice"
          },
          {
            "name": "bob",
            "role": "customer",
            "tenant": "tenant-b",
            "username": "bob"
          }
        ],
        "expectedPolicy": {
          "id": "multi-role-default",
          "name": "Multi-role expected authorization",
          "description": "Expected policy for local multi-role app: customers can access own orders but not admin routes",
          "subjects": [
            { "id": "subj-customer", "name": "customer", "role": "customer" },
            { "id": "subj-admin", "name": "admin", "role": "admin" }
          ],
          "rules": [
            {
              "id": "rule-deny-admin",
              "description": "Customers should not access admin user endpoints",
              "subjectId": "subj-customer",
              "route": "/api/admin/",
              "method": "GET",
              "action": "deny",
              "confidence": "high"
            },
            {
              "id": "rule-allow-orders-own",
              "description": "Customers should access their own order endpoints",
              "subjectId": "subj-customer",
              "route": "/api/orders/",
              "method": "GET",
              "action": "allow",
              "confidence": "high"
            }
          ],
          "createdAt": "2025-01-01T00:00:00.000Z"
        },
        "expect": {
          "queueAfterTwoContexts": "Run read-only cross-role authorization comparison",
          "findingWithoutPolicy": {
            "confidence": "low",
            "severity": "medium"
          },
          "findingWithPolicy": {
            "confidence": "high",
            "severity": "high"
          }
        }
      }
    },
